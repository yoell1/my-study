<!DOCTYPE html>
<html lang="ko">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>레이아웃 실습 - kh 아카데미</title>
    <!--폰트어썸 아이콘 CDN-->
    <script src="https://kit.fontawesome.com/3dd9964fc0.js" crossorigin="anonymous"></script>
<style>
    /* 1. 기본 스타일 리셋 및 중앙 정렬 */
    * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
    }
    body {
        font-family: 'Malgun Gothic', sans-serif;
        background-color: #f8f9fa;
        color: #333;
    }

    header, main, footer {
        max-width: 1200px;
        width: 100%;
        margin: 0 auto; /* 좌우 여백 자동 계산 (중앙 정렬) */
        padding: 0 20px; /* 양옆 여백 부여 */
    }

    a {
        text-decoration: none;
        color: inherit;
    }
    ul {
        list-style: none;
    }

    /* 2. 상단 헤더 영역 (로고, 검색창, 로그인) */
    header > div:first-child {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 20px 0;
    }
    header .search {
        display: flex;
        border: 2px solid #333;
        width: 400px;
    }
    header .search input {
        width: 100%;
        border: none;
        padding: 10px;
        outline: none;
    }
    header .search button {
        border: none;
        background: none;
        padding: 0 15px;
        cursor: pointer;
    }
    header .header-util a {
        margin-left: 15px;
        font-size: 14px;
    }

    /* 네비게이션 메뉴 바 */
    nav {
        border-top: 1px solid #ddd;
        border-bottom: 1px solid #ddd;
    }
    nav > ul {
        display: flex;
    }
    nav > ul > li {
        position: relative;
    }
    nav > ul > li > a {
        display: block;
        padding: 15px 25px;
        font-weight: bold;
    }
    .submenu {
        display: none; /* 실제 구현 시 호버 효과 필요 */
        position: absolute;
        background: #fff;
        border: 1px solid #ddd;
    }

    /* 3. 메인 콘텐츠 영역 (좌측 섹션 + 우측 어사이드 구조) */
    main {
        display: flex;
        gap: 30px; /* 좌우 컴포넌트 간격 */
        margin-top: 30px;
        margin-bottom: 50px;
    }
    main section {
        flex: 3; /* 메인 영역이 3만큼 차지 */
    }
    main aside {
        flex: 1; /* 로그인/바로가기가 1만큼 차지 */
        display: flex;
        flex-direction: column;
        gap: 20px;
    }

    /* 배너 영역 */
    .banner {
        background-color: #f1f3f5;
        padding: 40px;
        border: 1px solid #ddd;
        border-radius: 4px;
        margin-bottom: 20px;
    }
    .banner h2 {
        margin: 15px 0;
        font-size: 28px;
    }

    /* 공지사항 띠 */
    .notice {
        display: flex;
        align-items: center;
        background: #fff;
        border: 1px solid #ddd;
        padding: 12px 20px;
        border-radius: 4px;
        margin-bottom: 20px;
    }
    .notice .tag {
        background: #333;
        color: #fff;
        padding: 3px 8px;
        font-size: 12px;
        font-weight: bold;
        margin-right: 15px;
    }
    .notice .more {
        margin-left: auto;
        color: #666;
    }

    /* 카드 리스트 (가로 배열) */
    .cards {
        display: flex;
        gap: 20px;
    }
    .card {
        flex: 1;
        background: #fff;
        border: 1px solid #ddd;
        border-radius: 4px;
        overflow: hidden;
    }
    .card .thumb {
        height: 150px;
        background-color: #e9ecef; /* 시안의 빈 박스 효과 */
        border-bottom: 1px solid #ddd;
    }
    .card .body {
        padding: 20px;
    }
    .card .body h3 {
        margin-bottom: 10px;
    }
    .card .body p {
        color: #666;
        font-size: 14px;
    }

    /* 우측 로그인 박스 */
    .login {
        background: #fff;
        border: 1px solid #ddd;
        padding: 25px;
        border-radius: 4px;
    }
    .login h3 {
        margin-bottom: 15px;
    }
    .login input {
        width: 100%;
        padding: 12px;
        margin-bottom: 10px;
        border: 1px solid #ddd;
        border-radius: 4px;
    }
    .login button {
        width: 100%;
        padding: 12px;
        background: #007bff;
        color: #fff;
        border: none;
        border-radius: 4px;
        font-weight: bold;
        cursor: pointer;
        margin-bottom: 15px;
    }
    .login div {
        display: flex;
        justify-content: space-between;
        font-size: 12px;
        color: #666;
    }

    /* 우측 바로가기 박스 */
    aside > div:last-child {
        background: #fff;
        border: 1px solid #ddd;
        padding: 25px;
        border-radius: 4px;
    }
    aside > div:last-child h3 {
        margin-bottom: 15px;
        border-bottom: 1px solid #ddd;
        padding-bottom: 10px;
    }
    aside > div:last-child ul li {
        padding: 12px 0;
        border-bottom: 1px solid #f1f3f5;
        display: flex;
        justify-content: space-between;
    }
    aside > div:last-child ul li::after {
        content: "→";
        color: #aaa;
    }

    /* 4. 하단 푸터 영역 */
    footer {
        border-top: 1px solid #ddd;
        padding-top: 30px;
        padding-bottom: 50px;
        color: #666;
        font-size: 13px;
    }
    footer div:first-child {
        margin-bottom: 15px;
    }
    footer div:first-child a {
        margin-right: 20px;
        font-weight: bold;
    }
    footer div:nth-child(2) p {
        margin-bottom: 5px;
    }
    footer > p {
        margin-top: 15px;
        color: #999;
    }
    /* 1. 마우스를 올렸을 때 서브메뉴 보이게 하기 */
nav > ul > li:hover .submenu {
    display: block;
}

/* 2. 서브메뉴가 메인 메뉴 아래에 자연스럽게 겹쳐서 뜨도록 디자인 조정 */
.submenu {
    display: none;             /* 기본 상태는 숨김 */
    position: absolute;        /* 메인 메뉴 글자 기준으로 위치 고정 */
    top: 100%;                 /* 메인 메뉴 바로 아래에 정렬 */
    left: 0;
    min-width: 160px;          /* 서브메뉴 상자의 최소 가로폭 */
    background-color: #ffffff; /* 배경색 하얀색 */
    border: 1px solid #ddd;    /* 테두리 선 */
    box-shadow: 0px 4px 8px rgba(0,0,0,0.1); /* 살짝 부드러운 그림자 효과 */
                   
}

/* 3. 서브메뉴 안의 개별 링크 스타일 */
.submenu li a {
    display: block;
    padding: 10px 15px;
    font-size: 14px;
    font-weight: normal;       /* 서브메뉴는 얇은 글씨체로 변경 */
    border-bottom: 1px solid #f1f3f5;
}

/* 4. 서브메뉴 항목에 마우스 올렸을 때 배경색 변하게 하기 */
.submenu li a:hover {
    background-color: #f8f9fa;
    color: #007bff;            /* 마우스 올리면 파란색 글씨로 포인트 */
}

</style>

</head>

<body>
