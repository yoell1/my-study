package com.kh.ex3;

import java.util.Scanner;

public class Quiz3 {

	public static void main(String[] args) {
		// TODO Auto-generated method stub
/*
 * **입력 예시**
- 소문자와 대문자의 아스키코드 값 차이는 32입니다. `a = 97`, `A = 65`
- 더하기 연산 : `+` , 빼기 연산 : `-`
- 문자를 입력 받는 함수 : `next()` , `nextLine()` —> `String`
```java
소문자 입력: a
```

**출력 예시**

```bash
소문자: a
대문자: A
```
 */
	     Scanner sc = new Scanner(System.in);
	     
		 char a;
			 
		System.out.print("소문자 입력 : ");
		 
		 String str = sc.next();
		 
		 //문자열길이 : str.length()

		 //특정 위치의 한 문자를 추출 : 문자열 charAt(위치);
		 // 위치 : 기본적으로 0부터 시작
		 // " happy" -> "happy".charAt(0) => 'h'
		 //          -> "happy".charAt(3) => 'p'
		 //          -> "happy".charAt(4) => 'y'
		a = str.charAt(0);
		 
		// System.out.println("입력 받은 값 : " + str);
		// System.out.println("추출 한 값:" + a);
		// 소문자를 대문자로 변환(자료형)
		 //'a' = 97, 'A' = 65
		 char result = (char)(a -32);
		 
		 System.out.println("소문자 : " + a);
		 System.out.println("대문자 : " +result);
				 
		 sc.close();
		 
		
		
	}

}

