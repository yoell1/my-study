[조건문]
- 프로그램의 흐름을 "조건"에 따라 제어하는 문법
- 조건식을 통해 참인지 거짓인지 판단하여 해당하는 코드 실행

  * 조건식의 결과 : true 또는 false => boolean (논리형)
  * 자주 사용되는 연산 : 비교 연산자( > < >= <= == !=), 논리 연산자 ( &&  || )

- 종류
  1. if 문

       [1] 단독 if문 => 조건을 만족하는 경우만 실행
        * 표현법 (아래에 작성)
		if (조건식) {
			// 조건식의 결과가 true일 때 실행할 내용
		}

       [2] if ~ else문 => 조건을 만족하는 경우와 만족하지 않는 경우를 분기하여 실행
        * 표현법 (아래에 작성)
		if (조건식) {
			// 조건식의 결과가 true일 때 실행할 내용
		} else {
			// 조건식의 결과가 false일 때 실행할 내용
		}

       [3] if ~ else if ~ else문
        * 표현법 (아래에 작성)
		if (조건식1) {
			// 조건식1의 결과가 true일 때 실행할 내용
		} else if (조건식2) {
			// 조건식1의 결과가 false이고, 조건식2의 결과가 true일 때 실행할 내용
		} else {
			// 조건식1, 조건식2의 결과가 false일 때 실행할 내용
		}
 
  2. switch 문 => 동등 비교를 수행하여 결과에 따라 흐름 제어

        * 표현법 (아래에 작성)

			switch (비교대상) {
				case 값1:
					// 비교대상 == 값1 일 때 실행할 내용
					break;
				case 값2:
					// 비교대상 == 값2 일 때 실행할 내용
					break;
				...
				default:
					// 모든 case에 해당하지 않을 때 실행할 내용
					break;
			}
        
