## Java 코드 예시

학생(Student) 정보를 관리하는 간단한 Java 예제 코드를 통해 구조를 이해해 봅시다.

### [1] Model (데이터와 로직)

```java
package model;

public class Student {
    private int id;
    private String name;

    // 데이터를 담는 생성자
    public Student(int id, String name) {
        this.id = id;
        this.name = name;
    }

    // Getter & Setter (데이터 그 자체에만 집중)
    public int getId() { return id; }
    public void setId(int id) { this.id = id; }

    public String getName() { return name; }
    public void setName(String name) { this.name = name; }
}
```
### [2] Controller (중간 제어)

```java
package controller;

import model.Student;

public class StudentController {
    // 임시로 데이터를 저장할 변수
    private Student model = null; 

    // 데이터 저장 기능 (입력된 데이터를 받아 Model 객체로 저장)
    public void registerStudent(int id, String name) {
        this.model = new Student(id, name);
        System.out.println("=> [System] 학생 등록이 완료되었습니다.");
    }

    // 데이터 조회 기능 (저장된 Model이 있는지 검증하고 반환)
    public Student getStudent() {
        return this.model;
    }
}
```
[3] View (화면 출력)

package view;

import controller.StudentController;
import model.Student;
import java.util.Scanner;

public class StudentView {
    private StudentController controller;
    private Scanner scanner;
    
    public StudentView() {
	    this.controller = new StudentController();
	    this.scanner = new Scanner(System.util.System.in);
    }

    // 메뉴 화면을 보여주고 입력을 처리하는 화면 중심 로직
    public void startMenu() {
        while (true) {
            System.out.println("\n======= 학생 관리 시스템 =======");
            System.out.println("1. 학생 등록 | 2. 학생 조회 | 3. 종료");
            System.out.print("메뉴를 선택하세요: ");
            int menu = scanner.nextInt();
            scanner.nextLine(); // 버퍼 비우기

            if (menu == 1) {
                uiRegister(); // 등록 화면으로 이동
            } else if (menu == 2) {
                uiDisplay();  // 조회 화면으로 이동
            } else if (menu == 3) {
                System.out.println("프로그램을 종료합니다.");
                break;
            } else {
                System.out.println("잘못된 메뉴 선택입니다.");
            }
        }
    }

    // 등록 화면 출력
    private void uiRegister() {
        System.out.println("\n--- [학생 등록 화면] ---");
        System.out.print("학번 입력: ");
        int id = scanner.nextInt();
        scanner.nextLine();
        System.out.print("이름 입력: ");
        String name = scanner.nextLine();

        // 사용자가 입력을 마치면 Controller에게 데이터 저장을 지시!
        controller.registerStudent(id, name);
    }

    // 조회 화면 출력
    private void uiDisplay() {
        System.out.println("\n--- [학생 조회 화면] ---");
        // Controller를 통해 저장된 Model 데이터를 요청
        Student student = controller.getStudent();

        if (student == null) {
            System.out.println("=> [System] 등록된 학생 정보가 없습니다. 먼저 등록해주세요.");
        } else {
            System.out.println("=====================");
            System.out.println("학번: " + student.getId());
            System.out.println("이름: " + student.getName());
            System.out.println("=====================");
        }
    }
}

[4] Main (실행 클래스)

import controller.StudentController;
import view.StudentView;

public class Run {
    public static void main(String[] args) {
        // 1. 화면을 담당할 View 생성
        StudentView view = new StudentView();

        // 2. 메인이 실행되면 오직 View를 통해서만 화면이 시작됨
        view.startMenu();
    }
}
